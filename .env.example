# Environment Variables for ControlApp Mobile
# Copy this file to .env and fill in the values

# API Backend URL (REST - for Auth)
EXPO_PUBLIC_API_URL=https://ptr.controlapp.site/api

# GraphQL Endpoint
EXPO_PUBLIC_GRAPHQL_URL=https://ptr.controlapp.site/graphql

# For local development with Android Emulator:
# EXPO_PUBLIC_API_URL=http://10.0.2.2:8000/api
# EXPO_PUBLIC_GRAPHQL_URL=http://10.0.2.2:8000/graphql

# For local development with iOS Simulator:
# EXPO_PUBLIC_API_URL=http://localhost:8000/api
# EXPO_PUBLIC_GRAPHQL_URL=http://localhost:8000/graphql
